{
  "name": "warden",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "approvedBuilds": [
      "@swc/core",
      "esbuild"
    ]
  },
  "imports": {
    "#database": "./dist/database/index.js",
    "#database/*": "./dist/database/*.js",
    "#lib": "./dist/lib/index.js",
    "#lib/*": "./dist/lib/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/database/migrate.js && node dist/index.js",
    "db:generate": "drizzle-kit generate --config=src/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=src/drizzle.config.ts",
    "db:pull": "drizzle-kit pull",
    "i18n:extract": "i18next-cli extract",
    "i18n:sync": "i18next-cli extract --sync-primary",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,json}": "prettier --check"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "i18next": "^26.0.10",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "stoatx": "^0.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "i18next-cli": "^1.56.11",
    "lint-staged": "^17.0.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "private": true
}
