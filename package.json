{
  "name": "warden",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ],
    "approvedBuilds": [
      "@swc/core",
      "esbuild"
    ]
  },
  "scripts": {
