    "stoatx": "^0.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.1",
    "drizzle-kit": "^0.31.10",
    "i18next-cli": "^1.56.11",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=24.0.0"
